# ==================== 直播间配置 ====================
# B站直播间ID
BILIBILI_ROOM_ID=1990578187

# ==================== Bilibili Cookie ====================
# 登录B站后从浏览器获取
BILIBILI_SESSDATA=
BILIBILI_BILI_JCT=
BILIBILI_BUVID3=

# ==================== OpenRouter API ====================
# 从 https://openrouter.ai 获取 API Key
OPENROUTER_API_KEY=

# 可选：使用其他模型
# OPENROUTER_MODEL=minimax/minimax-m2.5:free

# ==================== LLM 配置 ====================
# 可选：自定义人设prompt
# CHARACTOR_PROMPT=你叫 心翎（XinLing），性格活泼开朗...

# 可选：调整回复长度和随机性
# MAX_TOKENS=100
# TEMPERATURE=0.7

# ==================== 功能开关 ====================
# 测试模式（开启后不会真正发送弹幕）
# TEST_MODE=false

# 仅测试弹幕读取
# TEST_DANMAKU_ONLY=false

# 仅测试LLM功能
# TEST_LLM_ONLY=false

# ==================== 行为配置 ====================
# 触发LLM回复的前缀
# TRIGGER_PREFIX=@xl

# 弹幕最大长度
# MAX_DANMAKU_LENGTH=30

# 回复弹幕前缀
# DANMAKU_PREFIX=[心翎]:

# 最大历史记录数
# MAX_HISTORY=10

# 礼物感谢冷却（秒）
# GIFT_THANK_COOLDOWN=60

# 同一用户感谢冷却（秒）
# USER_THANK_COOLDOWN=300

# ==================== 重连配置 ====================
# 重连延迟（秒）
# RECONNECT_DELAY=5

# 最大重连次数
# MAX_RECONNECT_ATTEMPTS=10